# ============================================
# EMC Website v2 - Environment Variables
# ============================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# ---- PostgreSQL Database ----
DATABASE_NAME=strapi
DATABASE_USERNAME=strapi
DATABASE_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ---- Strapi Secrets ----
# IMPORTANT: Generate unique values for production!
# Run this 6 times: openssl rand -base64 32
JWT_SECRET=GENERATE_ME
ADMIN_JWT_SECRET=GENERATE_ME
APP_KEYS=GENERATE_KEY1,GENERATE_KEY2,GENERATE_KEY3,GENERATE_KEY4
API_TOKEN_SALT=GENERATE_ME
TRANSFER_TOKEN_SALT=GENERATE_ME

# ---- Environment ----
NODE_ENV=production

# ---- pgAdmin (optional) ----
PGADMIN_EMAIL=admin@emcmarble.com
PGADMIN_PASSWORD=CHANGE_ME

# ---- Next.js Frontend ----
# NEXT_PUBLIC_ = visible in browser (used for client-side image URLs)
# Without NEXT_PUBLIC_ = server-side only (used for API fetching)
#
# Server-side: Next.js fetches data from Strapi internally via Docker network
STRAPI_URL=http://emc-strapi:1337
# Client-side: Browser loads images via your public Strapi domain
NEXT_PUBLIC_STRAPI_URL=https://strapi.yourdomain.com
# API token (create in Strapi admin > Settings > API Tokens)
STRAPI_API_TOKEN=paste-token-from-strapi-admin
# Your frontend public URL
NEXT_PUBLIC_SITE_URL=https://yourdomain.com

# ---- Nginx Proxy Manager ----
# Your frontend domain (added to Strapi CORS allowed origins)
CLIENT_URL=https://yourdomain.com
# Strapi hostname (for Next.js image optimization)
STRAPI_HOSTNAME=strapi.yourdomain.com
