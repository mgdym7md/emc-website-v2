{
  "kind": "collectionType",
  "collectionName": "contact_submissions",
  "info": {
    "singularName": "contact-submission",
    "pluralName": "contact-submissions",
    "displayName": "Contact Submission",
    "description": "Contact form submissions from the website"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "name": {
      "type": "string",
      "required": true,
      "maxLength": 255
    },
    "email": {
      "type": "email",
      "required": true
    },
    "interest": {
      "type": "string",
      "required": true,
      "maxLength": 100
    },
    "message": {
      "type": "text",
      "required": true
    },
    "submittedAt": {
      "type": "datetime",
      "required": true
    },
    "read": {
      "type": "boolean",
      "default": false
    }
  }
}
